#!/bin/sh

COMMIT_MSG_FILE="$1"
COMMIT_MSG=$(cat "$COMMIT_MSG_FILE")

# Allow bypassing with [skip-hooks] in commit message
if echo "$COMMIT_MSG" | grep -q "\[skip-hooks\]"; then
    echo "⚠️  Skipping version check due to [skip-hooks] in commit message."
    exit 0
fi

STAGED=$(git diff --cached --name-only)

# Require CHANGELOG.md to be staged
if ! echo "$STAGED" | grep -q "^CHANGELOG.md$"; then
    echo "❌ ERROR: CHANGELOG.md must be updated and staged before committing."
    exit 1
fi

# Require VERSION.md to be staged
if ! echo "$STAGED" | grep -q "^VERSION.md$"; then
    echo "❌ ERROR: VERSION.md must be updated and staged before committing."
    exit 1
fi

# Require frontend/package.json to be staged
if ! echo "$STAGED" | grep -q "^frontend/package.json$"; then
    echo "❌ ERROR: frontend/package.json must be updated and staged before committing."
    exit 1
fi

# Extract the top version from CHANGELOG.md (e.g. "v0.3.0" from "### v0.3.0 - ...")
CHANGELOG_VERSION=$(grep -m1 "^### v" CHANGELOG.md | sed 's/^### \(v[0-9][0-9.]*\).*/\1/')

# Extract version from package.json and prepend "v" for comparison
PKG_VERSION="v$(sed -n 's/.*"version": *"\([^"]*\)".*/\1/p' frontend/package.json | head -1)"

if [ -z "$CHANGELOG_VERSION" ]; then
    echo "❌ ERROR: Could not parse a version from CHANGELOG.md."
    exit 1
fi

if [ -z "$PKG_VERSION" ] || [ "$PKG_VERSION" = "v" ]; then
    echo "❌ ERROR: Could not parse a version from frontend/package.json."
    exit 1
fi

if [ "$PKG_VERSION" != "$CHANGELOG_VERSION" ]; then
    echo "❌ ERROR: frontend/package.json version ($PKG_VERSION) does not match CHANGELOG.md ($CHANGELOG_VERSION)."
    exit 1
fi

echo "✅ CHANGELOG.md and frontend/package.json both updated and versions match ($CHANGELOG_VERSION). Proceeding."
exit 0
